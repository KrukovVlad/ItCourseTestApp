<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/authFragment">

    <fragment
        android:id="@+id/authFragment"
        android:name="com.example.itcoursetestapp.presentation.auth.AuthFragment"
        android:label="AuthFragment"
        tools:layout="@layout/fragment_login">
        
        <action
            android:id="@+id/action_authFragment_to_mainContainerFragment"
            app:destination="@id/mainContainerFragment"
            app:popUpTo="@id/authFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/mainContainerFragment"
        android:name="com.example.itcoursetestapp.presentation.main.MainContainerFragment"
        android:label="MainContainerFragment"
        tools:layout="@layout/fragment_main_container" />

</navigation>

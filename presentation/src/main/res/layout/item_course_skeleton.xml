<?xml version="1.0" encoding="utf-8"?>
<com.facebook.shimmer.ShimmerFrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/margin_default"
    app:shimmer_auto_start="true"
    app:shimmer_base_alpha="0.2"
    app:shimmer_highlight_alpha="0.5"
    app:shimmer_duration="1200">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_course_card"
        android:paddingBottom="@dimen/margin_default">

        <View
            android:id="@+id/CourseImageSkeleton_v"
            android:layout_width="0dp"
            android:layout_height="@dimen/course_image_height"
            android:background="@drawable/bg_skeleton"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <View
            android:id="@+id/CourseTitleSkeleton_v"
            android:layout_width="@dimen/skeleton_title_width"
            android:layout_height="@dimen/skeleton_title_height"
            android:layout_marginTop="@dimen/margin_default"
            android:layout_marginStart="@dimen/margin_default"
            android:background="@drawable/bg_skeleton"
            app:layout_constraintTop_toBottomOf="@id/CourseImageSkeleton_v"
            app:layout_constraintStart_toStartOf="parent" />

        <View
            android:id="@+id/CourseDescSkeleton_v"
            android:layout_width="0dp"
            android:layout_height="@dimen/skeleton_desc_height"
            android:layout_marginTop="@dimen/margin_medium"
            android:layout_marginStart="@dimen/margin_default"
            android:layout_marginEnd="@dimen/margin_medium"
            android:background="@drawable/bg_skeleton"
            app:layout_constraintTop_toBottomOf="@id/CourseTitleSkeleton_v"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <View
            android:id="@+id/CoursePriceSkeleton_v"
            android:layout_width="@dimen/skeleton_price_width"
            android:layout_height="@dimen/skeleton_price_height"
            android:layout_marginTop="@dimen/margin_price_top"
            android:layout_marginStart="@dimen/margin_default"
            android:background="@drawable/bg_skeleton"
            app:layout_constraintTop_toBottomOf="@id/CourseDescSkeleton_v"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.facebook.shimmer.ShimmerFrameLayout>